# Read JSON files incrementally using Auto Loader
df = (
    spark.readStream.format("cloudFiles")
    .option("cloudFiles.format", "json")
    .option("cloudFiles.schemaLocation", "/tmp/schema")
    .load(source_path)
)

# Parse and reshape data as needed
reshaped_df = df.select(
    col("field1"),
    col("field2"),
    # Add more transformations as required
)

# Write to Bronze Delta table
reshaped_df.writeStream.format("delta") \
    .option("checkpointLocation", "/tmp/checkpoint") \
    .outputMode("append") \
    .table("bronze_table")